# Default: leave both empty. The UI talks to /api/v1/* and Vite's dev proxy
# (see vite.config.ts) forwards those to the Go API on :8090.

# Absolute URL prefix — set this only if the frontend is deployed on a
# different origin than the API.
VITE_API_BASE_URL=

# Set to "true" to force the built-in mock client (offline UI dev).
VITE_USE_MOCK=
