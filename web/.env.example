# Copy to .env.local for local Vite. On Vercel, set these under Project → Settings → Environment Variables.

# Public URL of the Go API (include scheme, no trailing slash). Required for production
# so the browser calls your API host; empty string only works with Vite dev proxy.
VITE_API_BASE_URL=https://your-api.example.com

# Set to true only for UI development without a backend
# VITE_USE_MOCK=false
