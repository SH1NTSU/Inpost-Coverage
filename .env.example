# --- HTTP API ---
HTTP_ADDR=:8090
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=30s
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Redis cache ---
# Leave REDIS_ADDR empty to fall back to an in-process LRU.
REDIS_ADDR=localhost:6380
REDIS_DB=0
REDIS_TTL=10m

# --- Database ---
DATABASE_URL=postgres://paczkomat:paczkomat@localhost:5432/paczkomat?sslmode=disable
DATABASE_MAX_CONNS=10

# --- Scraper ---
SCRAPER_INTERVAL=5m
SCRAPER_CITY=Kraków
SCRAPER_COUNTRY=PL
SCRAPER_PAGE_SIZE=100
SCRAPER_RATE_PER_SECOND=1

# --- External API ---
INPOST_BASE_URL=https://api-global-points.easypack24.net

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=json
